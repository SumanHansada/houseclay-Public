{
  "name": "zebra-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS='--inspect' next dev --turbopack --experimental-https",
    "build": "next build",
    "build:prod": "NODE_ENV=production next build",
    "start": "next start",
    "start:prod": "NODE_ENV=production next start",
    "lint": "next lint --fix",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "format": "prettier src --check --ignore-path .gitignore .",
    "format:fix": "eslint src --ext .js,.jsx,.ts,.tsx --fix && prettier --write --ignore-path .gitignore .",
    "prepare": "husky",
    "dev:zebra": "next dev --turbo",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed --debug",
    "e2e:watch": "npm e2e:headed -g \"@auth\""
  },
  "dependencies": {
    "@heroui/table": "^2.2.18",
    "@lottiefiles/dotlottie-react": "^0.14.2",
    "@reduxjs/toolkit": "^2.6.1",
    "@svgr/webpack": "^8.1.0",
    "@tanstack/react-query": "^5.69.0",
    "@types/lodash": "^4.17.16",
    "@vis.gl/react-google-maps": "^1.5.2",
    "axios": "^1.8.3",
    "date-fns": "^4.1.0",
    "focus-trap-react": "^11.0.3",
    "formik": "^2.4.6",
    "js-cookie": "^3.0.5",
    "lodash": "^4.17.21",
    "lucide-react": "^0.479.0",
    "motion": "^12.4.10",
    "next": "15.3.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-dropzone": "^14.3.8",
    "react-hot-toast": "^2.5.2",
    "react-international-phone": "^4.5.0",
    "react-loading-skeleton": "^3.5.0",
    "react-redux": "^9.2.0",
    "redux-persist": "^6.0.0",
    "uuid": "^11.1.0",
    "yup": "^1.6.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.1",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.18",
    "dotenv": "^17.2.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "15.3.2",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.3",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "postcss": "^8.4.35",
    "prettier": "^3.5.3",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
